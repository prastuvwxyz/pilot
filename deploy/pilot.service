[Unit]
Description=Pilot — Engineering Task Board
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/openclaw/pilot
ExecStart=/home/openclaw/pilot/pilot
Restart=always
RestartSec=5
Environment=ENV=production
EnvironmentFile=/home/openclaw/pilot/.env

# PATH must include openclaw
Environment=PATH=/home/openclaw/.nvm/versions/node/v24.14.0/bin:/usr/local/bin:/usr/bin:/bin

[Install]
WantedBy=default.target
